<%- include('includes/head.ejs') %>
   <title>חבר לרכב - הרשמה</title>
 </head>
 <body>
<%- include('includes/menu.ejs') %>


   <main>
     <section class="hero">
       <h2>הצטרפו לחבר לרכב</h2>
       <p>חשבון חינמי שמרכז את כל מה שקשור לרכב שלכם - טיפולים, דלק והמלצות - במקום אחד.</p>
     </section>


     <section class="split">
       <h2>הרשמה לאתר</h2>


       <aside class="col-side">
         <h3>למה כדאי להירשם?</h3>
         <p>תיעוד טיפולים והוצאות במקום אחד.</p>
         <p>מעקב אחרי צריכת הדלק שלכם לאורך זמן.</p>
         <p>המלצות על רכבים שמתאימים בדיוק לכם.</p>
       </aside>


       <form class="form-box register-form col-main" method="post" action="/register" onsubmit="return validateRegister()">
         <% if (error) { %>
           <p class="form-error"><%= error %></p>
         <% } %>
         <p id="registerError" class="form-error"></p>


         <p class="field">
           <label for="fname">שם פרטי:</label>
           <input type="text" id="fname" name="fname" maxlength="50" required />
         </p>


         <p class="field">
           <label for="lname">שם משפחה:</label>
           <input type="text" id="lname" name="lname" maxlength="50" required />
         </p>


         <p class="field">
           <label for="username">שם משתמש:</label>
           <input type="text" id="username" name="username" maxlength="50" required />
         </p>


         <p class="field">
           <label for="password">סיסמה:</label>
           <input type="password" id="password" name="password" required />
         </p>


         <p class="field">
           <label for="password2">אימות סיסמה:</label>
           <input type="password" id="password2" name="password2" required />
         </p>


         <p class="field">
           <label for="email">אימייל:</label>
           <input type="email" id="email" name="email" required />
         </p>


         <p class="field">
           <label for="phone">טלפון:</label>
           <input type="tel" id="phone" name="phone" pattern="0\d{8,9}" title="מספר טלפון תקין המתחיל ב-0, למשל 0501234567" required />
         </p>


         <p class="field">
           <label for="idnum">תעודת זהות:</label>
           <input type="text" id="idnum" name="idnum" pattern="\d{9}" title="תעודת זהות בת 9 ספרות" required />
         </p>


         <p class="field">
           <label for="birth">תאריך לידה:</label>
           <input type="date" id="birth" name="birth" max="<%= new Date().toISOString().slice(0,10) %>" title="תאריך לידה לא יכול להיות עתידי" required />
         </p>


         <p class="field">
           <label for="city">עיר מגורים:</label>
           <input type="text" id="city" name="city" maxlength="50" required />
         </p>


         <p class="field">
           <label for="license">מספר רישיון נהיגה:</label>
           <input type="text" id="license" name="license" required />
         </p>


         <p class="field">
           <label for="plate">מספר רכב (לוחית רישוי):</label>
           <input type="text" id="plate" name="plate" pattern="\d{7,8}" title="מספר רכב בן 7 עד 8 ספרות" required />
         </p>


         <p class="field-submit">
           <button type="submit">הרשמה</button>
         </p>


         <p class="auth-note">
           כבר רשומים? <a href="/login">להתחברות</a>
         </p>
       </form>
     </section>
   </main>


   <script src="/js/register.js"></script>
<%- include('includes/end.ejs') %>



