<%- include('includes/head.ejs') %>
   <title>חבר לרכב - פרטי רכב</title>
 </head>
 <body>
<%- include('includes/menu.ejs') %>


   <main>
     <section class="car-detail">
       <h2>פרטי רכב</h2>
       <article class="car-sheet">
         <h3><%= car.cname %></h3>
         <p class="price-tag">מחיר מחירון: <%= car.cprice %> ₪</p>
         <p class="car-desc"><%= car.cdesc %></p>
         <ul class="spec-grid">
           <li><span>יצרן</span><%= car.cmaker %></li>
           <li><span>שנת דגם</span><%= car.cyear %></li>
           <li><span>מספר מושבים</span><%= car.cseats %></li>
           <li><span>סוג רכב</span><%= car.cbody %></li>
           <li><span>סוג הנעה</span><%= car.cfuel %></li>
         </ul>
       </article>


       <article class="calc">
         <h3>מחשבון מימון</h3>
         <p>בדקו מה יהיה התשלום החודשי על רכב זה לפי מקדמה ומספר תשלומים.</p>


         <p class="field">
           <label for="down">מקדמה (₪):</label>
           <input type="number" id="down" value="0" />
         </p>


         <p class="field">
           <label for="months">מספר תשלומים (חודשים):</label>
           <input type="number" id="months" value="36" />
         </p>


         <input type="hidden" id="carPrice" value="<%= car.cprice %>" />
         <p><button type="button" onclick="calcFinance()">חשב תשלום חודשי</button></p>
         <p id="financeResult" class="finance-result"></p>
       </article>


       <p class="detail-back"><a href="/find-car" class="btn">חזרה למאגר הרכבים</a></p>
     </section>
   </main>


   <script>
     function calcFinance() {
       var carPrice = parseFloat(document.getElementById("carPrice").value);
       var down = parseFloat(document.getElementById("down").value);
       var months = parseInt(document.getElementById("months").value);
       var box = document.getElementById("financeResult");


       if (isNaN(carPrice)) {
         box.innerHTML = "אין מחיר מחירון לרכב זה";
         return;
       }
       if (isNaN(down) || down < 0) {
         box.innerHTML = "יש להזין סכום מקדמה תקין";
         return;
       }
       if (isNaN(months) || months <= 0) {
         box.innerHTML = "מספר התשלומים חייב להיות גדול מאפס";
         return;
       }


       if (down >= carPrice) {
         box.innerHTML = "המקדמה גבוהה או שווה למחיר הרכב - אין צורך במימון";
         return;
       }


       var loan = carPrice - down;
       var monthly = loan / months;
       box.innerHTML = "תשלום חודשי משוער: " + monthly.toFixed(0) + " ₪";
     }
   </script>


<%- include('includes/end.ejs') %>


