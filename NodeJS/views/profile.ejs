<%- include('includes/head.ejs') %>
   <title>חבר לרכב - האיזור האישי</title>
 </head>
 <body>
<%- include('includes/menu.ejs') %>


   <main>
     <section class="hero">
       <h2>שלום <%= user.fname %>!</h2>
       <p>זהו האיזור האישי שלך - כאן מרוכזים פרטי החשבון שלך.</p>
     </section>


     <section class="split">
       <h2>הפרטים שלי</h2>


       <aside class="col-side">
         <h3>קיצורי דרך</h3>
         <p><a href="/maintenance">מאגר הטיפולים הקהילתי</a></p>
         <p><a href="/find-car">מצא את הרכב הבא</a></p>
         <p><a href="/pricing">בדיקת מחירון</a></p>
         <p><a href="/fuel">יומן תדלוקים</a></p>
         <p><a href="/logout">יציאה מהחשבון</a></p>
       </aside>


       <article class="col-main">
         <section class="form-box">
           <p><strong>שם משתמש:</strong> <%= user.username %></p>
           <p><strong>שם מלא:</strong> <%= user.fname %> <%= user.lname %></p>
           <p><strong>אימייל:</strong> <%= user.email %></p>
           <p><strong>טלפון:</strong> <%= user.phone %></p>
           <p><strong>תעודת זהות:</strong> <%= user.idnum %></p>
           <p><strong>תאריך לידה:</strong> <%= user.birth %></p>
           <p><strong>עיר מגורים:</strong> <%= user.city %></p>
           <p><strong>מספר רישיון נהיגה:</strong> <%= user.license %></p>
           <p><strong>מספר רכב:</strong> <%= user.plate %></p>
         </section>
       </article>
     </section>
   </main>


<%- include('includes/end.ejs') %>



